# env.local — Environment variables for local development
#
# Copy to AdminServer/.env and fill in your values:
# % cp setupfiles/env.local AdminServer/.env
#
# This file is checked into version control as a template.
# AdminServer/.env is gitignored and should never be committed.
#
# NOTE: No CALLBACK_URL vars needed locally — config.js defaults to localhost.
# NOTE: No NODE_ENV needed locally — absence means development (Ethereal email).

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# Absolute path to the repo root
BASEDIR='/Users/yourname/dev/interference'

# Hostname used for cookie/session config
HOSTNAME='localhost'

# Port the React dev server runs on (used by AdminServer for CORS)
CLIENTPORT=3000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# MySQL password for the 'mysql' user
DATABASE_PASSWORD='your-db-password'

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Secret key for signing JWTs — use a long random string
JWT_SECRET_KEY='your-jwt-secret'

# URL the AdminClient is served from (used for OAuth redirect-back)
CLIENT_URL='https://localhost:3000'

# ---------------------------------------------------------------------------
# reCAPTCHA v3
# ---------------------------------------------------------------------------
# Get keys at: https://www.google.com/recaptcha/admin
# Site key is public (also set in AdminClient/src/config/config.js)

RECAPTCHA_SECRET_KEY='your-recaptcha-secret-key'

# ---------------------------------------------------------------------------
# React (AdminClient)
# ---------------------------------------------------------------------------
# These are baked into the frontend build — prefix required by Create React App

REACT_APP_SERVER_URL='https://localhost:8080'
REACT_APP_MIXENGINE_URL='https://localhost:8082'

# ---------------------------------------------------------------------------
# OAuth — Google
# ---------------------------------------------------------------------------
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://localhost:8080/api/auth/callback/google

GOOGLE_CLIENT_ID='your-google-client-id'
GOOGLE_CLIENT_SECRET='your-google-client-secret'

# ---------------------------------------------------------------------------
# OAuth — GitHub
# ---------------------------------------------------------------------------
# Console: https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: https://localhost:8080/api/auth/callback/github
# NOTE: GitHub allows only one callback URL per app — use a separate app for prod

GITHUB_CLIENT_ID='your-github-client-id'
GITHUB_CLIENT_SECRET='your-github-client-secret'

# ---------------------------------------------------------------------------
# OAuth — Discord
# ---------------------------------------------------------------------------
# Console: https://discord.com/developers/applications → OAuth2 → Redirects
# Add redirect: https://localhost:8080/api/auth/callback/discord

DISCORD_CLIENT_ID='your-discord-client-id'
DISCORD_CLIENT_SECRET='your-discord-client-secret'
